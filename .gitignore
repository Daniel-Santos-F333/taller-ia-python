# --- Entorno Virtual ---
# No subir el entorno virtual porque es local y pesado
venv/
env/
ENV/

# --- Cache de Python ---
# Archivos temporales generados al ejecutar el código
**/__pycache__/
*.py[cod]
*$py.class

# --- IDEs (Visual Studio Code) ---
# Configuraciones de tu editor que no afectan a otros
.vscode/
.history/

# --- Persistencia de Datos ---
